<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CFBundleDevelopmentRegion</key>
	<string>en</string>
	<key>CFBundleDisplayName</key>
	<string>whispr bro</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleName</key>
	<string>$(PRODUCT_NAME)</string>
	<key>CFBundlePackageType</key>
	<string>APPL</string>
	<!-- Keep in step with ../VERSION (single source of truth) until the
	     release flow stamps it in, like scripts/make-app.sh does on macOS. -->
	<key>CFBundleShortVersionString</key>
	<string>0.1.0</string>
	<!-- Deep-link target for the keyboard extension's mic key
	     (whisprbro://session/start — see KeyboardViewController). -->
	<key>CFBundleURLTypes</key>
	<array>
		<dict>
			<key>CFBundleURLName</key>
			<string>com.micaxes.whispr-bro.ios</string>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>whisprbro</string>
			</array>
		</dict>
	</array>
	<key>CFBundleVersion</key>
	<string>1</string>
	<key>NSMicrophoneUsageDescription</key>
	<string>whispr bro transcribes entirely on this device — audio never leaves it.</string>
	<!-- StartDictationIntent's Live Activity (issue #13 row-8 probe): the
	     system stops an AudioRecordingIntent recording without one. -->
	<key>NSSupportsLiveActivities</key>
	<true/>
	<!-- Fonts are copied to the bundle root by the ../Fonts group in
	     project.yml, so bare filenames resolve. -->
	<key>UIAppFonts</key>
	<array>
		<string>Archivo-Variable.ttf</string>
		<string>IBMPlexMono-Medium.ttf</string>
		<string>IBMPlexMono-Regular.ttf</string>
		<string>IBMPlexMono-SemiBold.ttf</string>
	</array>
	<key>UIApplicationSceneManifest</key>
	<dict>
		<key>UIApplicationSupportsMultipleScenes</key>
		<false/>
	</dict>
	<!-- Keeps transcription running when the app is backgrounded mid-dictation. -->
	<key>UIBackgroundModes</key>
	<array>
		<string>audio</string>
	</array>
	<key>UILaunchScreen</key>
	<dict/>
</dict>
</plist>
